# polymarket impulse bot (prefix only; timestamp auto-appended)
POLYMARKET_SLUG_PREFIX=btc-updown-15m
IMPULSE_WINDOW_SECONDS=900
IMPULSE_LIMIT_PRICE=0.55
IMPULSE_MIN_JUMP=0.05
IMPULSE_LOOKBACK_SEC=60
IMPULSE_TRAILING_STOP_PCT=5
IMPULSE_BUY_AMOUNT_USD=10
IMPULSE_POLL_INTERVAL_MS=2000

ENABLE_IMPULSE_BOT=true
ENABLE_AUTO_REDEEM=true

PRIVATE_KEY=your_ethereum_private_key
PROXY_WALLET_ADDRESS=your_polymarket_proxy_safe_address
# Optional: set these if credential.json gives 401 (from npm run credential:recreate output)
# POLY_API_KEY=
# POLY_SECRET=
# POLY_PASSPHRASE=
CLOB_API_URL=https://clob.polymarket.com
CHAIN_ID=137
RPC_URL=
RPC_TOKEN=

MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=polymarket_impulse
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

API_PORT=3003
